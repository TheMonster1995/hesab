# Copy to .env and adjust. Used by docker-compose and the API.

# --- Postgres ---
POSTGRES_USER=hesab
POSTGRES_PASSWORD=hesab
POSTGRES_DB=hesab

# --- API ---
# In Docker the API reaches Postgres at host "db". For local dev use localhost.
DATABASE_URL=postgresql://hesab:hesab@db:5432/hesab?schema=public
JWT_SECRET=change-me-please-use-a-long-random-string
API_PORT=4000

# --- Web ---
WEB_PORT=8080

# --- Production (docker-compose.prod.yml) ---
# Domain for automatic HTTPS via Caddy. DNS A record must point at the VPS.
DOMAIN=hesab.example.com
